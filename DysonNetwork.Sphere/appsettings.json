    "Etcd": {
        "Insecure": true
    },
    "Cache": {
        "Serializer": "JSON"
    },
    "Service": {
        "Name": "DysonNetwork.Sphere",
        "Url": "https://localhost:7099",
        "FitnessUrl": "https://localhost:5001"
    },
    "ActivityPubDelivery": {
        "MaxRetries": 5,
        "ConsumerCount": 4
    },
    "Automod": {
        "Rules": [
            {
                "Name": "Block known spam domains",
                "Description": "Derank posts containing links to known spam domains",
                "Type": "LinkBlocklist",
                "Action": "Derank",
                "Pattern": "(?i)(spamdomain\\.com|malware\\.net|phishingsite\\.org)",
                "IsRegex": true,
                "DerankWeight": 15,
                "IsEnabled": true,
                "Priority": 10
            },
            {
                "Name": "Block crypto scams",
                "Description": "Derank posts containing crypto scam patterns",
                "Type": "KeywordBlocklist",
                "Action": "Derank",
                "Pattern": "\\b(free crypto|double your (?:bitcoin|eth|coin)|yield farming|ponzi)\\b",
                "IsRegex": true,
                "DerankWeight": 20,
                "IsEnabled": true,
                "Priority": 20
            },
            {
                "Name": "Block explicit adult content links",
                "Description": "Hide posts containing links to adult content sites",
                "Type": "LinkBlocklist",
                "Action": "Hide",
                "Pattern": "(?i)(adultsite\\.com|xxx\\.com|18plus\\.net)",
                "IsRegex": true,
                "DerankWeight": 30,
                "IsEnabled": false,
                "Priority": 30
            }
        ]
    },
    "FediverseModeration": {
        "Rules": [
            {
                "Name": "Block known spam instances",
                "Description": "Block federation with known spam instances",
                "Type": "DomainBlock",
                "Action": "Block",
                "Domain": "spam-instance.example",
                "IsEnabled": true,
                "Priority": 10
            },
            {
                "Name": "Silence suspicious instances",
                "Description": "Silence posts from instances with suspicious activity",
                "Type": "DomainBlock",
                "Action": "Silence",
                "Domain": "suspicious.example",
                "IsEnabled": false,
                "Priority": 20
            }
        ]
    }
}
