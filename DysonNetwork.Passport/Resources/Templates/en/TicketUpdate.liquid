<div role="article" aria-roledescription="email" aria-label lang="en" style="font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif; color: #475569">
    <h1 style="font-size: 24px; color: #0f172a">Dear {{ nick }},</h1>
    <p>{{ message }}</p>
    <p><strong>Ticket:</strong> {{ ticketTitle }}</p>
    {% if latestMessage %}
    <p><strong>Latest reply:</strong></p>
    <p style="white-space: pre-wrap">{{ latestMessage }}</p>
    {% endif %}
    <p>
        <a href="{{ link }}" style="display: inline-block; padding: 12px 18px; border-radius: 4px; color: #fffffe; background-color: #020617; text-decoration: none">View Ticket</a>
    </p>
    <p>Thanks,<br><strong>Solar Network Team</strong></p>
</div>
